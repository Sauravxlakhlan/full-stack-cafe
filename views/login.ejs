<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Canteen Central</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
    </style>
</head>
<body class="bg-[#fdfcfb] text-slate-900 overflow-hidden">

    <div class="fixed top-[-10%] right-[-10%] w-[40%] h-[40%] bg-orange-100 rounded-full blur-[120px] opacity-60"></div>
    <div class="fixed bottom-[-10%] left-[-10%] w-[40%] h-[40%] bg-blue-50 rounded-full blur-[120px] opacity-60"></div>

    <div class="min-h-screen relative flex items-center justify-center p-6">
        <div class="max-w-md w-full relative">
            
            <div class="text-center mb-10 transition-all duration-700 transform translate-y-0">
                <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-tr from-orange-600 to-orange-400 rounded-2xl shadow-2xl shadow-orange-200 mb-6 rotate-3">
                    <i class="fa-solid fa-utensils text-white text-2xl"></i>
                </div>
                <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 mb-2">Welcome Back</h1>
                <p class="text-slate-500 font-medium">Elevate your lunch experience.</p>
            </div>

            <div class="glass-card rounded-[2.5rem] shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-white/50 p-10 relative overflow-hidden">
                
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="mb-6 p-4 bg-red-500/10 border border-red-500/20 text-red-600 text-xs font-bold rounded-2xl flex items-center gap-2 animate-pulse">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <%= error %>
                    </div>
                <% } %>

                <form action="/login" method="POST" class="space-y-5">
                    
                    <div class="group">
                        <label class="block text-[11px] font-extrabold uppercase tracking-[0.15em] text-slate-400 mb-2 ml-2 transition-colors group-focus-within:text-orange-600">Email Address</label>
                        <div class="relative">
                            <input type="email" name="email" placeholder="email@college.edu" 
                                class="w-full pl-6 pr-4 py-4 rounded-2xl bg-white/50 border border-slate-100 focus:border-orange-500 focus:ring-0 focus:shadow-[0_0_20px_rgba(234,88,12,0.1)] outline-none transition-all placeholder:text-slate-300 font-semibold text-slate-700" required>
                            <i class="fa-regular fa-envelope absolute right-6 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-orange-500 transition-colors"></i>
                        </div>
                    </div>

                    <div class="group">
                        <div class="flex justify-between items-center mb-2 ml-2">
                            <label class="text-[11px] font-extrabold uppercase tracking-[0.15em] text-slate-400 transition-colors group-focus-within:text-orange-600">Password</label>
                        </div>
                        <div class="relative">
                            <input type="password" name="password" placeholder="••••••••" 
                                class="w-full pl-6 pr-4 py-4 rounded-2xl bg-white/50 border border-slate-100 focus:border-orange-500 focus:ring-0 focus:shadow-[0_0_20px_rgba(234,88,12,0.1)] outline-none transition-all placeholder:text-slate-300 font-semibold text-slate-700" required>
                            <i class="fa-solid fa-lock text-sm absolute right-6 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-orange-500 transition-colors"></i>
                        </div>
                    </div>

                    <div class="flex items-center justify-between px-2">
                        <label class="flex items-center cursor-pointer group">
                            <input type="checkbox" id="remember" class="hidden peer">
                            <div class="w-5 h-5 border-2 border-slate-200 rounded-lg flex items-center justify-center peer-checked:bg-orange-600 peer-checked:border-orange-600 transition-all">
                                <i class="fa-solid fa-check text-[10px] text-white"></i>
                            </div>
                            <span class="ml-3 text-sm font-semibold text-slate-500 group-hover:text-slate-700 transition-colors">Remember me</span>
                        </label>
                        <a href="#" class="text-sm font-bold text-orange-600 hover:text-orange-700 transition-colors">Forgot?</a>
                    </div>
                    
                    <button type="submit" 
                        class="w-full bg-slate-900 text-white font-extrabold py-5 rounded-2xl shadow-xl shadow-slate-200 hover:bg-orange-600 hover:shadow-orange-100 transition-all transform hover:-translate-y-1 active:scale-[0.95] flex items-center justify-center gap-3">
                        Sign In
                        <i class="fa-solid fa-arrow-right-long text-sm"></i>
                    </button>
                </form>

                <div class="mt-10 pt-8 border-t border-slate-100 text-center">
                    <p class="text-slate-400 font-semibold text-sm">
                        New student? 
                        <a href="/signup" class="text-orange-600 font-extrabold hover:underline decoration-2 underline-offset-4 ml-1">
                            Create Account
                        </a>
                    </p>
                </div>
            </div>

            <div class="mt-12 flex items-center justify-center gap-6 opacity-40 grayscale hover:grayscale-0 transition-all duration-500">
                <span class="text-[10px] font-black tracking-[0.2em] uppercase text-slate-600">Fast Delivery</span>
                <div class="w-1 h-1 bg-slate-400 rounded-full"></div>
                <span class="text-[10px] font-black tracking-[0.2em] uppercase text-slate-600">Fresh Food</span>
                <div class="w-1 h-1 bg-slate-400 rounded-full"></div>
                <span class="text-[10px] font-black tracking-[0.2em] uppercase text-slate-600">Campus Only</span>
            </div>
        </div>
    </div>

</body>
</html>