<div id="cart-overlay" class="fixed inset-0 bg-black/40 z-50 hidden opacity-0 transition-opacity duration-300" onclick="togglePanel('cart-overlay', false)">
    <div class="absolute right-0 top-0 h-full w-full max-w-sm bg-white shadow-xl translate-x-full transition-transform duration-300 flex flex-col" onclick="event.stopPropagation()">
        <div class="p-6 border-b flex justify-between items-center">
            <h2 class="text-xl font-bold text-gray-900">Your Cart</h2>
            <button onclick="togglePanel('cart-overlay', false)" class="text-gray-400 hover:text-gray-900 text-2xl">&times;</button>
        </div>
        <div class="p-6">
            <label class="block text-xs font-bold text-gray-400 uppercase mb-2">Pickup Time</label>
            <input type="time" id="pickup-time" class="w-full p-3 bg-gray-50 border border-gray-200 rounded-lg outline-none focus:border-orange-500 font-bold">
        </div>
        <div id="cart-container" class="flex-1 overflow-y-auto px-6 space-y-3"></div>
        <div class="p-6 border-t bg-gray-50">
            <div class="flex justify-between items-center mb-4">
                <span class="text-gray-600 font-bold">Total</span>
                <span id="cart-total" class="text-2xl font-bold text-gray-900">$0.00</span>
            </div>
            <button onclick="checkout()" class="w-full bg-orange-600 text-white py-4 rounded-lg font-bold hover:bg-orange-700 transition-colors shadow-lg">Place Order</button>
        </div>
    </div>
</div>

<div id="orders-overlay" class="fixed inset-0 bg-black/40 z-50 hidden opacity-0 transition-opacity duration-300" onclick="togglePanel('orders-overlay', false)">
    <div class="absolute right-0 top-0 h-full w-full max-w-sm bg-white shadow-xl translate-x-full transition-transform duration-300 flex flex-col" onclick="event.stopPropagation()">
        <div class="p-6 border-b flex justify-between items-center">
            <h2 class="text-xl font-bold text-gray-900">My Orders</h2>
            <button onclick="togglePanel('orders-overlay', false)" class="text-gray-400 hover:text-gray-900 text-2xl">&times;</button>
        </div>
        <div class="flex-1 overflow-y-auto p-6 space-y-4">
            <% if (typeof myOrders !== 'undefined' && myOrders.length > 0) { %>
                <% myOrders.forEach(order => { %>
                    <div class="bg-white border border-gray-200 rounded-xl p-4 shadow-sm">
                        <div class="flex justify-between mb-2">
                            <span class="text-[10px] font-bold text-gray-400">#<%= order._id.toString().slice(-6) %></span>
                            <span class="text-[10px] font-bold uppercase text-orange-600 bg-orange-50 px-2 py-0.5 rounded"><%= order.status %></span>
                        </div>
                        <p class="text-sm font-medium text-gray-800 mb-3"><%= order.items.map(i => i.name).join(', ') %></p>
                        <div class="flex justify-between items-center pt-3 border-t border-gray-50">
                            <span class="font-bold">$<%= order.totalAmount %></span>
                            <button onclick="handleFastReorder(this)" 
                                    data-items='<%- JSON.stringify(order.items) %>' 
                                    data-total="<%= order.totalAmount %>"
                                    class="text-xs font-bold text-orange-600 hover:underline">Re-order</button>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="text-center py-20 text-gray-300 font-bold">No orders found</div>
            <% } %>
        </div>
    </div>
</div>

<div id="logoutModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm" onclick="hideLogoutModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-sm p-6">
        <div class="bg-white rounded-3xl shadow-2xl p-8 text-center modal-animate">
            <div class="w-16 h-16 bg-orange-50 rounded-2xl flex items-center justify-center mx-auto mb-6">
                <i class="fa-solid fa-right-from-bracket text-orange-600 text-xl"></i>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Ready to Leave?</h3>
            <p class="text-gray-500 text-sm mb-8">You're about to logout.</p>
            <div class="flex flex-col gap-3">
                <a href="/logout" class="w-full bg-slate-900 text-white font-bold py-4 rounded-xl hover:bg-red-600 transition-all shadow-lg text-center">Logout</a>
                <button onclick="hideLogoutModal()" class="w-full bg-slate-50 text-slate-600 font-bold py-4 rounded-xl hover:bg-slate-100 transition-all">Cancel</button>
            </div>
        </div>
    </div>
</div>